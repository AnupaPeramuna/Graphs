{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 550,
  "title": {
    "text": "Train Station Distribution Across Victorian Local Government Areas (LGA)",
    "fontSize": 16,
    "anchor": "start",
    "offset": 20
  },
  "config": {
    "background": "#f9f9f9"
  },
  "projection": {
    "type": "mercator",
    "center": [145.0, -36.5],
    "scale": 4200
  },
  "layer": [
    {
      "data": {
        "url": "LGA_POLYGON.json",
        "format": {
          "type": "topojson",
          "feature": "LGA_POLYGON"
        }
      },
      "params": [
      
    {
      "name": "zoom_and_pan",
      "select": "interval",
      "bind": "scales"
    },

        {
          "name": "hover",
          "select": {
            "type": "point", 
            "on": "mouseover", 
            "empty": false
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "fill": {
          "condition": {
            "param": "hover", 
            "value": "#4a90e2"
          },
          "value": "#dcdcdc"
        },
        "tooltip": [
          {
            "field": "properties.LGA_NAME", 
            "type": "nominal", 
            "title": "LGA"
          }   
        ]
      }
    },
    {
      "data": {
        "url": "TrainStops.csv" 
      },
      "transform": [
  {
          "filter": "datum.location_type == '1'"

  }],
      "mark": {
        "type": "circle",
        "size": 50,
        "color": "#ff4d4d",
        "opacity": 0.4,
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "longitude": {
          "field": "stop_lon", 
          "type": "quantitative"
        },
        "latitude": {
          "field": "stop_lat", 
          "type": "quantitative"
        }}
      }


    
  ]
}