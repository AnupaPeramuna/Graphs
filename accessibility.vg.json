{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 300,
  "title": "Average Wait Time (Accessibility)",
  "data": {"url": "accessibility.csv"},
  "mark": {"type": "line", "point": true},
  "encoding": {
    "x": {"field": "hour", "type": "quantitative", "title": "Hour"},
    "y": {"field": "avg_wait_time", "type": "quantitative", "title": "Avg Wait Time (Minutes)"},
    "color": {"field": "Region_Type", "type": "nominal"},
    "facet": {"field": "Day", "type": "nominal", "columns": 1}
  }
}