{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Weekly Rail Services per 10,000 Residents by LGA",
  "width": 700,
  "height": 600,
  "projection": {
    "type": "mercator",
    "center": [144.9, -37.8],
    "scale": 18000
  },
  "data": {
    "url": "LGA_POLYGON.json",
    "format": {
      "type": "topojson",
      "feature": "LGA_POLYGON"
    }
  },
  "transform": [
    {
      "lookup": "properties.ABSLGACODE",
      "from": {
        "data": { "url": "FINAL_lga_services_per_10k.csv" },
        "key": "ABSLGACODE",
        "fields": ["LGA_NAME", "population", "actual_stop_count", "weekly_avg_services", "weekly_services_per_10k"]
      }
    },
    {
      "calculate": "datum.weekly_services_per_10k == null ? 0 : datum.weekly_services_per_10k",
      "as": "services_display"
    },
    {
      "calculate": "datum.LGA_NAME == null ? datum.properties.LGA_NAME : datum.LGA_NAME",
      "as": "display_name"
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 0.5
  },
  "encoding": {
    "color": {
      "field": "services_display",
      "type": "quantitative",
      "title": "Services per 10k residents",
      "scale": {
        "type": "sqrt",
        "domain": [0, 1, 50, 150, 500],
        "range": ["#d3d3d3", "#c6dbef", "#6baed6", "#2171b5", "#08306b"]
      }
    },
    "tooltip": [
      { "field": "display_name", "type": "nominal", "title": "LGA" },
      { "field": "population", "type": "quantitative", "title": "Population", "format": "," },
      { "field": "actual_stop_count", "type": "quantitative", "title": "Train stops", "format": ".0f" },
      { "field": "weekly_avg_services", "type": "quantitative", "title": "Weekly services", "format": ".0f" },
      { "field": "services_display", "type": "quantitative", "title": "Services per 10k", "format": ".2f" }
    ]
  }
}